rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    // API Keys index (admin SDK only — no client access)
    match /apiKeys/{keyHash} {
      allow read, write: if false;
    }

    // Users: only the owner can access their own document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Agents subcollection
      match /agents/{agentId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;

        // Skills
        match /skills/{skillId} {
          allow read, write: if request.auth != null && request.auth.uid == userId;
        }

        // Tools
        match /tools/{toolId} {
          allow read, write: if request.auth != null && request.auth.uid == userId;
        }

        // Extensions
        match /extensions/{extensionId} {
          allow read, write: if request.auth != null && request.auth.uid == userId;
        }

        // Versions
        match /versions/{versionId} {
          allow read, write: if request.auth != null && request.auth.uid == userId;
        }

        // MCP Servers
        match /mcpServers/{serverId} {
          allow read, write: if request.auth != null && request.auth.uid == userId;

          // Usage (read-only for owner, writes via admin SDK only)
          match /usage/{yearMonth} {
            allow read: if request.auth != null && request.auth.uid == userId;
            allow write: if false;
          }
        }

        // Grading Suites
        match /gradingSuites/{suiteId} {
          allow read, write: if request.auth != null && request.auth.uid == userId;

          // Cases
          match /cases/{caseId} {
            allow read, write: if request.auth != null && request.auth.uid == userId;
          }

          // Runs
          match /runs/{runId} {
            allow read, write: if request.auth != null && request.auth.uid == userId;

            // Run Results
            match /results/{resultId} {
              allow read, write: if request.auth != null && request.auth.uid == userId;
            }
          }
        }

        // Pipelines
        match /pipelines/{pipelineId} {
          allow read, write: if request.auth != null && request.auth.uid == userId;
        }

        // Sessions (Observability)
        match /sessions/{sessionId} {
          allow read, write: if request.auth != null && request.auth.uid == userId;
        }

        // Connectors (widget, slack)
        match /connectors/{connectorId} {
          allow read, write: if request.auth != null && request.auth.uid == userId;
        }

        // Webhooks
        match /webhooks/{webhookId} {
          allow read, write: if request.auth != null && request.auth.uid == userId;
        }

        // Webhook Logs (read-only for owner, writes via admin SDK)
        match /webhookLogs/{logId} {
          allow read: if request.auth != null && request.auth.uid == userId;
          allow write: if false;
        }

        // AutoResearch Runs (read-only for owner, writes via admin SDK)
        match /autoresearchRuns/{runId} {
          allow read: if request.auth != null && request.auth.uid == userId;
          allow write: if false;

          // Iterations
          match /iterations/{iterationId} {
            allow read: if request.auth != null && request.auth.uid == userId;
            allow write: if false;
          }
        }
      }

      // Agent Teams (user-level)
      match /agentTeams/{teamId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Usage / Billing (user-level)
      match /usage/{yearMonth} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      // Bugs (owner read/write, creation via admin SDK from bug report API)
      match /bugs/{bugId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // GDPR Consent preferences
      match /consent/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Slack Teams index (admin SDK only — no client access)
    match /slackTeams/{teamId} {
      allow read, write: if false;
    }

    // Telegram Bots index (admin SDK only — no client access)
    match /telegramBots/{hash} {
      allow read, write: if false;
    }

    // WhatsApp Phones index (admin SDK only — no client access)
    match /whatsappPhones/{phoneId} {
      allow read, write: if false;
    }

    // Error Logs (admin read via client SDK, writes via admin SDK only)
    match /errorLogs/{logId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
