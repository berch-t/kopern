rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Generated images — public read, admin SDK write only
    match /generated-images/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if false; // Admin SDK bypasses rules
    }

    // Deny all other paths
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
